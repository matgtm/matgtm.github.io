---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { TOPICS, TOPIC_LABELS } from "../lib/topics";

const STATUS_LABELS = {
  "no leido": "No leido",
  "en progreso": "En progreso",
  leido: "Leido",
  listo: "Ficha lista"
};

const AUTHOR_LABELS = {
  humano: "Humano",
  codex: "Codex",
  mixto: "Mixto"
};

const toClassName = (value: string) => value.replaceAll(" ", "-");

const papers = (await getCollection("papers")).sort((a, b) => {
  const topicA = TOPIC_LABELS[a.data.topic]?.index ?? 0;
  const topicB = TOPIC_LABELS[b.data.topic]?.index ?? 0;
  if (topicA !== topicB) return topicA - topicB;
  return a.data.year - b.data.year || a.data.title.localeCompare(b.data.title);
});

const grouped = TOPICS.map((topic) => ({
  ...topic,
  papers: papers.filter((paper) => paper.data.topic === topic.id)
}));

const totalPapers = papers.length;
const corePapers = papers.filter((paper) => paper.data.core).length;
const readPapers = papers.filter((paper) => ["leido", "listo"].includes(paper.data.status)).length;
---

<BaseLayout title="Papers Fundamentales de NLP">
  <main class="page">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">matgtm.github.io</p>
        <h1>Papers fundamentales de NLP, ordenados para estudiar.</h1>
        <p class="hero-text">
          Una biblioteca personal para preparar el parcial, mantener un archivo propio y completar
          fichas de lectura paper por paper sin perder el mapa general del campo.
        </p>
      </div>

      <aside class="hero-panel">
        <p class="hero-kicker">Primera iteracion</p>
        <dl class="hero-stats">
          <div>
            <dt>Papers</dt>
            <dd>{totalPapers}</dd>
          </div>
          <div>
            <dt>Temas</dt>
            <dd>{TOPICS.length}</dd>
          </div>
          <div>
            <dt>Estado</dt>
            <dd>{readPapers} leidos</dd>
          </div>
          <div>
            <dt>Clave</dt>
            <dd>{corePapers}</dd>
          </div>
        </dl>
      </aside>
    </section>

    <section class="legend-card" aria-labelledby="legend-title">
      <div class="legend-copy">
        <p class="eyebrow">Codigo de lectura</p>
        <h2 id="legend-title">El color de cada bloque indica quien escribio esa parte.</h2>
      </div>
      <div class="legend-items">
        <div class="legend-sample voice-human">
          <span>Humano</span>
          <p>Tu voz: mas organica, con lectura propia, intuiciones y asociaciones personales.</p>
        </div>
        <div class="legend-sample voice-codex">
          <span>Codex</span>
          <p>Mi voz: mas mecanica, azulada y facil de auditar antes de confiar.</p>
        </div>
        <div class="legend-sample core-sample">
          <span><span class="key-dot" aria-hidden="true"></span>Clave</span>
          <p>El punto dorado marca papers que conviene priorizar si estas estudiando contra reloj.</p>
        </div>
      </div>
    </section>

    <section class="controls">
      <div class="control-grid">
        <label class="control">
          <span>Buscar</span>
          <input id="search-input" type="search" placeholder="Titulo, keyword o tema" />
        </label>

        <label class="control">
          <span>Estado</span>
          <select id="status-filter">
            <option value="">Todos</option>
            <option value="no leido">No leido</option>
            <option value="en progreso">En progreso</option>
            <option value="leido">Leido</option>
            <option value="listo">Ficha lista</option>
          </select>
        </label>

        <label class="control">
          <span>Tema</span>
          <select id="topic-filter">
            <option value="">Todos</option>
            {TOPICS.map((topic) => <option value={topic.id}>{topic.shortLabel}</option>)}
          </select>
        </label>

        <label class="control">
          <span>Clave</span>
          <select id="core-filter">
            <option value="">Todos</option>
            <option value="true">Solo clave</option>
          </select>
        </label>
      </div>

      <nav class="topic-nav" aria-label="Navegacion rapida por tema">
        {TOPICS.map((topic) => (
          <a href={`#${topic.id}`} class="topic-pill">
            {topic.shortLabel}
          </a>
        ))}
      </nav>

      <p id="empty-state" class="empty-state" hidden>
        No hay papers que coincidan con los filtros actuales.
      </p>
    </section>

    <section class="topic-sections">
      {grouped.map((topic) => (
        <section id={topic.id} class="topic-card" data-topic-section>
          <header class="topic-header">
            <div>
              <p class="topic-eyebrow">{topic.papers.length} papers</p>
              <h2>{topic.label}</h2>
            </div>
            <p>{topic.description}</p>
          </header>

          <div class="table-shell">
            <table>
              <thead>
                <tr>
                  <th>Paper</th>
                  <th>Anio</th>
                  <th>Fuente</th>
                  <th>Estado</th>
                  <th>Pagina</th>
                </tr>
              </thead>
              <tbody>
                {topic.papers.map((paper) => (
                  <tr
                    data-topic={paper.data.topic}
                    data-status={paper.data.status}
                    data-title={paper.data.title}
                    data-keywords={[paper.data.keywords.join(" "), paper.data.memoryCue, paper.data.authors].join(" ")}
                    data-topic-label={topic.label}
                    data-core={String(paper.data.core)}
                    class:list={["paper-row", paper.data.core && "is-core"]}
                  >
                    <td>
                      <div class="paper-title-wrap">
                        <div class="paper-title-line">
                          {paper.data.core && <span class="key-dot" title="Clave" aria-label="Clave"></span>}
                          <a class="paper-link" href={`/papers/${paper.slug}/`}>
                            {paper.data.title}
                          </a>
                        </div>
                        <p>{paper.data.memoryCue}</p>
                        {paper.data.writtenBy && (
                          <div class="paper-flags">
                          <span class={`author-chip author-${toClassName(paper.data.writtenBy)}`}>
                            {AUTHOR_LABELS[paper.data.writtenBy]}
                          </span>
                          </div>
                        )}
                      </div>
                    </td>
                    <td>{paper.data.year}</td>
                    <td>
                      <a href={paper.data.sourceUrl} target="_blank" rel="noreferrer">
                        Ir al paper
                      </a>
                    </td>
                    <td>
                      <span class={`status-badge status-${toClassName(paper.data.status)}`}>
                        {STATUS_LABELS[paper.data.status]}
                      </span>
                    </td>
                    <td>
                      <a href={`/papers/${paper.slug}/`}>Abrir ficha</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ))}
    </section>
  </main>

  <script is:inline>
    const normalize = (value) =>
      value
        .toLowerCase()
        .normalize("NFD")
        .replace(/\p{Diacritic}/gu, "")
        .trim();

    const searchInput = document.querySelector("#search-input");
    const statusFilter = document.querySelector("#status-filter");
    const topicFilter = document.querySelector("#topic-filter");
    const coreFilter = document.querySelector("#core-filter");
    const rows = [...document.querySelectorAll(".paper-row")];
    const sections = [...document.querySelectorAll("[data-topic-section]")];
    const emptyState = document.querySelector("#empty-state");

    const applyFilters = () => {
      const query = normalize(searchInput?.value ?? "");
      const status = statusFilter?.value ?? "";
      const topic = topicFilter?.value ?? "";
      const core = coreFilter?.value ?? "";

      let visibleCount = 0;

      rows.forEach((row) => {
        const haystack = normalize(
          [row.dataset.title, row.dataset.keywords, row.dataset.topicLabel].filter(Boolean).join(" ")
        );
        const matchesQuery = !query || haystack.includes(query);
        const matchesStatus = !status || row.dataset.status === status;
        const matchesTopic = !topic || row.dataset.topic === topic;
        const matchesCore = !core || row.dataset.core === core;
        const visible = matchesQuery && matchesStatus && matchesTopic && matchesCore;

        row.toggleAttribute("hidden", !visible);
        if (visible) visibleCount += 1;
      });

      sections.forEach((section) => {
        const visibleRows = section.querySelectorAll(".paper-row:not([hidden])").length;
        section.toggleAttribute("hidden", visibleRows === 0);
      });

      emptyState?.toggleAttribute("hidden", visibleCount !== 0);
    };

    [searchInput, statusFilter, topicFilter, coreFilter].forEach((node) =>
      node?.addEventListener("input", applyFilters)
    );
    [statusFilter, topicFilter, coreFilter].forEach((node) =>
      node?.addEventListener("change", applyFilters)
    );
  </script>
</BaseLayout>
